@model HomeModel
@{
    ViewData["Title"] = "Confirmação de Apagar Contato";
}
<div class="text-center">
    <h3>Deseja mesmo apagar esse contato?</h3>
</div>
<div class="d-grid gap-2">
    <a class="btn btn-primary" role="button" asp-controller="Contato" asp-action="Index" d-grid gap-2>Cancelar Exclusão</a>
    <a class="btn btn-danger" role="button" d-grid gap-2 asp-controller="Contato" asp-action="Apagar">Confirmar Exclusão</a>
</div>